PORT=3000
NODE_ENV=production

# Optional first-run admin password.
# If data/users.json already exists, change the password from the admin panel instead.
ADMIN_PASSWORD=Admin123!

# Optional stable session signing secret for hosted deployments.
# Use a long random value and keep it private.
SERVER_SECRET=

# Optional image hosting. Leave blank to store uploads in the local uploads/ folder.
IMGBB_API_KEY=
# Optional. Useful for temporary test uploads. Leave blank/0 for normal permanent hosted images.
IMGBB_EXPIRATION_SECONDS=0

# Optional Supabase mirror. Leave blank to use local JSON only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTENT_TABLE=site_content
SUPABASE_AUDIT_TABLE=audit_log
SUPABASE_CONTENT_KEY=menu-real-estate-content
SUPABASE_USERS_KEY=menu-real-estate-users
SUPABASE_AUDIT_KEY=menu-real-estate-audit
